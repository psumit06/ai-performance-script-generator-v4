{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Comprehensive API Testing - GET/POST Scenarios",
    "description": "This collection demonstrates all common GET and POST scenarios, including authentication token correlation, variable chaining, different body types, parameters, and tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.example.com",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "resourceId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "POST Login - Generate Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Token is present\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.be.ok;",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "GET User Profile (Authenticated)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: \"Authorization\",",
                  "    value: \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));",
                  "const jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"userId\", jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "profile"]
            }
          }
        },
        {
          "name": "GET User by ID (Path Parameter)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: \"Authorization\",",
                  "    value: \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Resource CRUD",
      "item": [
        {
          "name": "POST Create Resource (JSON Body)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: \"Authorization\",",
                  "    value: \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Resource created\", () => pm.response.to.have.status(201));",
                  "const jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"resourceId\", jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Resource\",\n  \"description\": \"Created via Postman\",\n  \"price\": 99.99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/resources",
              "host": ["{{baseUrl}}"],
              "path": ["resources"]
            }
          }
        },
        {
          "name": "GET List Resources (Query Parameters)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: \"Authorization\",",
                  "    value: \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/resources?page=1&limit=10&search=test&status=active",
              "host": ["{{baseUrl}}"],
              "path": ["resources"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "test" },
                { "key": "status", "value": "active" }
              ]
            }
          }
        },
        {
          "name": "GET Single Resource (Path Param)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: \"Authorization\",",
                  "    value: \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/resources/{{resourceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "{{resourceId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "📤 POST Body Variations",
      "item": [
        {
          "name": "POST Form Data (x-www-form-urlencoded)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: \"Authorization\",",
                  "    value: \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "John Doe", "type": "text" },
                { "key": "email", "value": "john@example.com", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["users", "register"]
            }
          }
        },
        {
          "name": "POST Multipart Form Data + File Upload",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: \"Authorization\",",
                  "    value: \"Bearer \" + pm.collectionVariables.get(\"accessToken\")",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Upload Test", "type": "text" },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/upload",
              "host": ["{{baseUrl}}"],
              "path": ["upload"]
            }
          }
        },
        {
          "name": "POST with Nested JSON",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order\": {\n    \"items\": [\n      {\"productId\": 101, \"quantity\": 2}\n    ],\n    \"shippingAddress\": {\n      \"street\": \"123 Main St\",\n      \"city\": \"Anytown\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            }
          }
        }
      ]
    },
    {
      "name": "Advanced GET Scenarios",
      "item": [
        {
          "name": "GET with Headers & Query Params",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Custom-Header", "value": "test-value" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/search?category=electronics&minPrice=100&maxPrice=500&sort=price_desc",
              "host": ["{{baseUrl}}"],
              "path": ["search"],
              "query": [
                { "key": "category", "value": "electronics" },
                { "key": "minPrice", "value": "100" },
                { "key": "maxPrice", "value": "500" },
                { "key": "sort", "value": "price_desc" }
              ]
            }
          }
        }
      ]
    }
  ],
